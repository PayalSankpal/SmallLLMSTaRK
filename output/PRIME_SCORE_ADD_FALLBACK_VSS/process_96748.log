'R-DRE-381753', 'stIdVersion': 'R-DRE-381753.1', 'isInDisease': False, 'isInferred': True, 'name': ['Olfactory Signaling Pathway'], 'releaseDate': '2023-09-13', 'speciesName': 'Danio rerio', 'inferredFrom': [381753], 'hasDiagram': True, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10605043, 'displayName': 'Olfactory Signaling Pathway', 'stId': 'R-XTR-381753', 'stIdVersion': 'R-XTR-381753.1', 'isInDisease': False, 'isInferred': True, 'name': ['Olfactory Signaling Pathway'], 'releaseDate': '2023-09-13', 'speciesName': 'Xenopus tropicalis', 'inferredFrom': [381753], 'hasDiagram': True, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10699094, 'displayName': 'Olfactory Signaling Pathway', 'stId': 'R-GGA-381753', 'stIdVersion': 'R-GGA-381753.1', 'isInDisease': False, 'isInferred': True, 'name': ['Olfactory Signaling Pathway'], 'releaseDate': '2023-09-13', 'speciesName': 'Gallus gallus', 'inferredFrom': [381753], 'hasDiagram': True, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}]
