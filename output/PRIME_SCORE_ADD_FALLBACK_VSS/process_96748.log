: 'Ligand-receptor interactions', 'stId': 'R-BTA-5632681', 'stIdVersion': 'R-BTA-5632681.1', 'isInDisease': False, 'isInferred': True, 'name': ['Ligand-receptor interactions'], 'releaseDate': '2023-09-13', 'speciesName': 'Bos taurus', 'inferredFrom': [5632681], 'hasDiagram': False, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10168438, 'displayName': 'Ligand-receptor interactions', 'stId': 'R-CFA-5632681', 'stIdVersion': 'R-CFA-5632681.1', 'isInDisease': False, 'isInferred': True, 'name': ['Ligand-receptor interactions'], 'releaseDate': '2023-09-13', 'speciesName': 'Canis familiaris', 'inferredFrom': [5632681], 'hasDiagram': False, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10065281, 'displayName': 'Ligand-receptor interactions', 'stId': 'R-RNO-5632681', 'stIdVersion': 'R-RNO-5632681.1', 'isInDisease': False, 'isInferred': True, 'name': ['Ligand-receptor interactions'], 'releaseDate': '2023-09-13', 'speciesName': 'Rattus norvegicus', 'inferredFrom': [5632681], 'hasDiagram': False, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 9955031, 'displayName': 'Ligand-receptor interactions', 'stId': 'R-MMU-5632681', 'stIdVersion': 'R-MMU-5632681.1', 'isInDisease': False, 'isInferred': True, 'name': ['Ligand-receptor interactions'], 'releaseDate': '2023-09-13', 'speciesName': 'Mus musculus', 'inferredFrom': [5632681], 'hasDiagram': False, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}]
