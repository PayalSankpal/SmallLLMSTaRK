e, 'name': ['Activation of SMO'], 'releaseDate': '2023-09-13', 'speciesName': 'Danio rerio', 'inferredFrom': [5635838], 'hasDiagram': False, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10604435, 'displayName': 'Activation of SMO', 'stId': 'R-XTR-5635838', 'stIdVersion': 'R-XTR-5635838.1', 'isInDisease': False, 'isInferred': True, 'name': ['Activation of SMO'], 'releaseDate': '2023-09-13', 'speciesName': 'Xenopus tropicalis', 'inferredFrom': [5635838], 'hasDiagram': False, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10698490, 'displayName': 'Activation of SMO', 'stId': 'R-GGA-5635838', 'stIdVersion': 'R-GGA-5635838.1', 'isInDisease': False, 'isInferred': True, 'name': ['Activation of SMO'], 'releaseDate': '2023-09-13', 'speciesName': 'Gallus gallus', 'inferredFrom': [5635838], 'hasDiagram': False, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10780331, 'displayName': 'Activation of SMO', 'stId': 'R-DME-5635838', 'stIdVersion': 'R-DME-5635838.1', 'isInDisease': False, 'isInferred': True, 'name': ['Activation of SMO'], 'releaseDate': '2023-09-13', 'speciesName': 'Drosophila melanogaster', 'inferredFrom': [5635838], 'hasDiagram': False, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}]
