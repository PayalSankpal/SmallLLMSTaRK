releaseDate': '2023-09-13', 'speciesName': 'Danio rerio', 'inferredFrom': [2122948], 'hasDiagram': False, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10384909, 'displayName': 'Activated NOTCH1 Transmits Signal to the Nucleus', 'stId': 'R-SSC-2122948', 'stIdVersion': 'R-SSC-2122948.1', 'isInDisease': False, 'isInferred': True, 'name': ['Activated NOTCH1 Transmits Signal to the Nucleus'], 'releaseDate': '2023-09-13', 'speciesName': 'Sus scrofa', 'inferredFrom': [2122948], 'hasDiagram': False, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10279240, 'displayName': 'Activated NOTCH1 Transmits Signal to the Nucleus', 'stId': 'R-BTA-2122948', 'stIdVersion': 'R-BTA-2122948.1', 'isInDisease': False, 'isInferred': True, 'name': ['Activated NOTCH1 Transmits Signal to the Nucleus'], 'releaseDate': '2023-09-13', 'speciesName': 'Bos taurus', 'inferredFrom': [2122948], 'hasDiagram': False, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 9955511, 'displayName': 'Activated NOTCH1 Transmits Signal to the Nucleus', 'stId': 'R-MMU-2122948', 'stIdVersion': 'R-MMU-2122948.1', 'isInDisease': False, 'isInferred': True, 'name': ['Activated NOTCH1 Transmits Signal to the Nucleus'], 'releaseDate': '2023-09-13', 'speciesName': 'Mus musculus', 'inferredFrom': [2122948], 'hasDiagram': False, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}]
