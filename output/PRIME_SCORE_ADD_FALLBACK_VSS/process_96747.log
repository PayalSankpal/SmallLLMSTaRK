R-BTA-9018682', 'stIdVersion': 'R-BTA-9018682.1', 'isInDisease': False, 'isInferred': True, 'name': ['Biosynthesis of maresins'], 'releaseDate': '2023-09-13', 'speciesName': 'Bos taurus', 'inferredFrom': [9018682], 'hasDiagram': False, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10169710, 'displayName': 'Biosynthesis of maresins', 'stId': 'R-CFA-9018682', 'stIdVersion': 'R-CFA-9018682.1', 'isInDisease': False, 'isInferred': True, 'name': ['Biosynthesis of maresins'], 'releaseDate': '2023-09-13', 'speciesName': 'Canis familiaris', 'inferredFrom': [9018682], 'hasDiagram': False, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10066603, 'displayName': 'Biosynthesis of maresins', 'stId': 'R-RNO-9018682', 'stIdVersion': 'R-RNO-9018682.1', 'isInDisease': False, 'isInferred': True, 'name': ['Biosynthesis of maresins'], 'releaseDate': '2023-09-13', 'speciesName': 'Rattus norvegicus', 'inferredFrom': [9018682], 'hasDiagram': False, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 9956377, 'displayName': 'Biosynthesis of maresins', 'stId': 'R-MMU-9018682', 'stIdVersion': 'R-MMU-9018682.1', 'isInDisease': False, 'isInferred': True, 'name': ['Biosynthesis of maresins'], 'releaseDate': '2023-09-13', 'speciesName': 'Mus musculus', 'inferredFrom': [9018682], 'hasDiagram': False, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}]
