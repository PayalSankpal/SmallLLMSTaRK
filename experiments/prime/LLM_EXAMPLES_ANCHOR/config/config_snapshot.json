{
  "experiment": {
    "dataset": "prime",
    "split": "test",
    "exp_name": "LLM_EXAMPLES_ANCHOR",

    "test_run": false,
    "output_base_dir": "./retard/prime",
    "logging_level": "INFO"
  },
  "pipeline": {
    "max_workers": 24,
    "timeout_seconds": 300,
    "max_queries_test_run": 50
  },
  "models": {
    "llm_name": "meta/llama-3.3-70b-instruct",
    "llm_config_path": "configs.json",
    "embedding_model": "text-embedding-ada-002",
    "embedding_base_path": "../BtechProject/stark/emb"
  },
  "retrieval_params": {
    "step3_candidate_generation": {
      "initial_limit": 20,
      "vss_cutoff": 0.75
    },
    "step5_vss_merge": {
      "alpha": 14,
      "top_k": 20,
      "cutoff": 0.6
    }
  },
  "grounding_params": {
    "max_candidates_per_symbol": 3000,
    "max_answer_candidates": 20,
    "top_k_neighbors": 20,
    "support_boost": 0.0,
    "score_decay": 1
  },
  "data_paths": {
    "use_saved_llm_responses": false,
    "llm_responses_file": "llm_responses_batch/prime/test/gpt-4-1-mini-2025-04-14/llm_response_dataset_prime_gpt-4-1-mini-2025-04-14_flat.csv",
    "use_saved_vss_candidates": false,
    "vss_candidates_json_path": "vss_candidates.json"
  },
  "pipeline_v2": {
    "use_anchor_verification": true,
    "use_answer_direct_vss": true,
    "answer_direct_vss_k": 100,
    "grounding_min_threshold": 5,
    "use_llm_reranking": true,
    "rerank_pool_size": 50,
    "rerank_top_k": 20
  }
}
