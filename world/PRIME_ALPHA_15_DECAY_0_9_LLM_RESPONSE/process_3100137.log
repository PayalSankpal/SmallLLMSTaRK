 ['Signaling by BMP'], 'releaseDate': '2023-09-13', 'speciesName': 'Sus scrofa', 'inferredFrom': [201451], 'hasDiagram': True, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10278230, 'displayName': 'Signaling by BMP', 'stId': 'R-BTA-201451', 'stIdVersion': 'R-BTA-201451.1', 'isInDisease': False, 'isInferred': True, 'name': ['Signaling by BMP'], 'releaseDate': '2023-09-13', 'speciesName': 'Bos taurus', 'inferredFrom': [201451], 'hasDiagram': True, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10167920, 'displayName': 'Signaling by BMP', 'stId': 'R-CFA-201451', 'stIdVersion': 'R-CFA-201451.1', 'isInDisease': False, 'isInferred': True, 'name': ['Signaling by BMP'], 'releaseDate': '2023-09-13', 'speciesName': 'Canis familiaris', 'inferredFrom': [201451], 'hasDiagram': True, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10064751, 'displayName': 'Signaling by BMP', 'stId': 'R-RNO-201451', 'stIdVersion': 'R-RNO-201451.1', 'isInDisease': False, 'isInferred': True, 'name': ['Signaling by BMP'], 'releaseDate': '2023-09-13', 'speciesName': 'Rattus norvegicus', 'inferredFrom': [201451], 'hasDiagram': True, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 9954497, 'displayName': 'Signaling by BMP', 'stId': 'R-MMU-201451', 'stIdVersion': 'R-MMU-201451.1', 'isInDisease': False, 'isInferred': True, 'name': ['Signaling by BMP'], 'releaseDate': '2023-09-13', 'speciesName': 'Mus musculus', 'inferredFrom': [201451], 'hasDiagram': True, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}]
