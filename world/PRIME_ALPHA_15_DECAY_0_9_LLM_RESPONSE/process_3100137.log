'speciesName': 'Xenopus tropicalis', 'inferredFrom': [525793], 'hasDiagram': True, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10504281, 'displayName': 'Myogenesis', 'stId': 'R-DRE-525793', 'stIdVersion': 'R-DRE-525793.1', 'isInDisease': False, 'isInferred': True, 'name': ['Myogenesis'], 'releaseDate': '2023-09-13', 'speciesName': 'Danio rerio', 'inferredFrom': [525793], 'hasDiagram': True, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10384127, 'displayName': 'Myogenesis', 'stId': 'R-SSC-525793', 'stIdVersion': 'R-SSC-525793.1', 'isInDisease': False, 'isInferred': True, 'name': ['Myogenesis'], 'releaseDate': '2023-09-13', 'speciesName': 'Sus scrofa', 'inferredFrom': [525793], 'hasDiagram': True, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10278458, 'displayName': 'Myogenesis', 'stId': 'R-BTA-525793', 'stIdVersion': 'R-BTA-525793.1', 'isInDisease': False, 'isInferred': True, 'name': ['Myogenesis'], 'releaseDate': '2023-09-13', 'speciesName': 'Bos taurus', 'inferredFrom': [525793], 'hasDiagram': True, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10168138, 'displayName': 'Myogenesis', 'stId': 'R-CFA-525793', 'stIdVersion': 'R-CFA-525793.1', 'isInDisease': False, 'isInferred': True, 'name': ['Myogenesis'], 'releaseDate': '2023-09-13', 'speciesName': 'Canis familiaris', 'inferredFrom': [525793], 'hasDiagram': True, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 10064981, 'displayName': 'Myogenesis', 'stId': 'R-RNO-525793', 'stIdVersion': 'R-RNO-525793.1', 'isInDisease': False, 'isInferred': True, 'name': ['Myogenesis'], 'releaseDate': '2023-09-13', 'speciesName': 'Rattus norvegicus', 'inferredFrom': [525793], 'hasDiagram': True, 'hasEHLD': False, 'className': 'Pathway', 'schemaClass': 'Pathway'}, {'dbId': 9954729, 'displayName': 'Myogenesis', 'stId': 'R-MMU-525793', 'stIdVersion': 'R-MMU-525793.1', 'isInDisea